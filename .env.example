# 默认运行无需 .env；仅在显式管理凭据时运行 `udpfile keygen` 生成本文件。
# 真实共享密钥和私钥不得提交到 Git。
UDPFILE_SERVER_ADDR=127.0.0.1:9000
UDPFILE_ROOT=./shared
UDPFILE_WEB_LISTEN=127.0.0.1:8080
UDPFILE_TARGET_IP=127.0.0.1
UDPFILE_TARGET_PORT=9000
UDPFILE_SHARED_SECRET=REPLACE_WITH_BASE64_32_BYTE_SECRET
UDPFILE_RSA_PRIVATE_KEY=keys/server-private.pem
UDPFILE_RSA_PUBLIC_KEY=keys/server-public.pem
