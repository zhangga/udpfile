# 默认运行无需 .env；显式配置必须保存在共享根目录之外。
# 真实共享密钥和私钥不得提交到 Git。
UDPFILE_SERVER_ADDR=0.0.0.0:30033
UDPFILE_ROOT=.
UDPFILE_WEB_LISTEN=127.0.0.1:8080
UDPFILE_TARGET_IP=127.0.0.1
UDPFILE_TARGET_PORT=30033
UDPFILE_SHARED_SECRET=REPLACE_WITH_BASE64_32_BYTE_SECRET
UDPFILE_RSA_PRIVATE_KEY=/path/outside/shared/server-private.pem
UDPFILE_RSA_PUBLIC_KEY=/path/outside/shared/server-public.pem
